---
const stats = [
  { label: 'Core Languages', value: '3+', detail: 'Python, C++, Rust' },
  { label: 'Linux Distros', value: '8+', detail: 'Explored & Used' },
  { label: 'AI Models', value: '14B', detail: 'Params Run Locally' },
  { label: 'Open Source', value: '∞', detail: 'Love & Support' },
];
---
<section id="about" class="reel-section" data-reel="1">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 right-1/5 w-72 h-72 bg-emerald-500/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <div class="glass-card overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-white/[0.02]">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            <span class="ml-3 text-xs font-mono text-gray-500">godwin@fedora: ~</span>
          </div>
          <div class="p-6 font-mono text-sm leading-relaxed">
            <p class="text-gray-500">$ <span class="text-emerald-400">cat</span> about.md</p>
            <div class="mt-3 space-y-3 text-gray-300">
              <p>A <span class="text-accent-light">self-taught developer</span> who loves and supports open-source tools. I enjoy customizing and optimizing my own system, exploring command-line environments, and keeping up with the fast-paced evolution of technology.</p>
              <p class="text-gray-500">$ <span class="text-emerald-400">neofetch</span> --os</p>
              <p class="text-purple-400">Fedora Workstation (GNOME)</p>
              <p class="text-gray-500">$ <span class="text-emerald-400">echo</span> $PHILOSOPHY</p>
              <p class="text-yellow-300">"Build from Web to OS — just with a Text Editor"</p>
              <p class="text-gray-600 animate-pulse">▊</p>
            </div>
          </div>
        </div>
      </div>
      <div class="reveal" style="transition-delay:200ms">
        <p class="section-label">About Me</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-8">
          Developer. Tinkerer.<br /><span class="gradient-text">Linux Enthusiast.</span>
        </h2>
        <div class="grid grid-cols-2 gap-4">
          {stats.map((stat) => (
            <div class="glass-card glass-card-hover p-5 text-center">
              <p class="text-2xl sm:text-3xl font-bold text-white mb-1">{stat.value}</p>
              <p class="text-xs font-mono text-accent-light mb-1">{stat.label}</p>
              <p class="text-xs text-gray-500">{stat.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
