---
const name = 'Godwin Binoy';
const tagline = 'Building from Web to OS — just with a Text Editor';
---
<section id="hero" class="reel-section" data-reel="0">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/10 rounded-full blur-[128px] animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-purple-600/8 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay:2s"></div>
  </div>
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full glass-card mb-8 text-sm text-gray-400">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      <span class="font-mono">Kerala, India</span>
    </div>
    <h1 class="reveal text-5xl sm:text-7xl lg:text-8xl font-black tracking-tight mb-6" style="transition-delay:100ms">
      <span class="text-white">Godwin</span><span class="gradient-text"> Binoy</span>
    </h1>
    <p class="reveal text-lg sm:text-xl lg:text-2xl text-gray-400 font-light max-w-2xl mx-auto mb-10 text-balance" style="transition-delay:200ms">
      {tagline}
    </p>
    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4" style="transition-delay:300ms">
      <a href="https://github.com/godwin-binoy" target="_blank" rel="noopener noreferrer"
        class="group px-8 py-3.5 rounded-xl bg-accent hover:bg-accent-dark text-white font-semibold transition-all duration-300 hover:shadow-[0_0_30px_rgba(99,102,241,0.4)] hover:-translate-y-0.5 flex items-center gap-2">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View GitHub
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a href="#about" class="px-8 py-3.5 rounded-xl glass-card glass-card-hover text-gray-300 font-medium flex items-center gap-2">
        Explore
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </a>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-500">
    <span class="text-xs font-mono tracking-widest uppercase">Scroll</span>
    <div class="w-5 h-8 rounded-full border border-gray-600 flex items-start justify-center p-1">
      <div class="w-1 h-2 rounded-full bg-accent animate-bounce"></div>
    </div>
  </div>
</section>
