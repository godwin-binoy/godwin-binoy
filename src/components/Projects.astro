---
const projects = [
  { name: 'Fedora Silverblue BlueBuild', description: 'Custom Fedora Silverblue-based distro optimized for Intel Meteor Lake, Lunar Lake & Arrow Lake architectures.', tech: ['Shell', 'BlueBuild', 'Fedora', 'OSTree'], link: 'https://github.com/godwin-binoy/fedora-silverblue-bluebuild', icon: '🛡️', gradient: 'from-blue-600/20 to-cyan-600/20' },
  { name: 'Ozone', description: 'A seizure detection algorithm based on data from accelerometer and gyroscope sensors.', tech: ['HTML', 'Algorithms', 'Sensor Data', 'Health'], link: 'https://github.com/godwin-binoy/ozone', icon: '🧠', gradient: 'from-purple-600/20 to-pink-600/20' },
  { name: 'CLI Beginner Projects', description: 'Collection of programming projects created while learning — now merged into a single Astro-powered repository.', tech: ['Astro', 'Python', 'CLI', 'Learning'], link: 'https://github.com/godwin-binoy/cli-beginer-projects', icon: '⚡', gradient: 'from-emerald-600/20 to-teal-600/20' },
];
---
<section id="projects" class="reel-section" data-reel="4">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute bottom-1/3 left-1/4 w-72 h-72 bg-pink-600/5 rounded-full blur-[100px]"></div>
  </div>
  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-14">
      <p class="section-label justify-center">Work</p>
      <h2 class="reveal text-3xl sm:text-5xl font-bold text-white">Featured <span class="gradient-text">Projects</span></h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <a href={project.link} target="_blank" rel="noopener noreferrer"
          class="reveal group glass-card glass-card-hover p-6 flex flex-col h-full" style={`transition-delay:${i * 100}ms`}>
          <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${project.gradient} flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform duration-300`}>{project.icon}</div>
          <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-accent-light transition-colors">{project.name}</h3>
          <p class="text-sm text-gray-400 leading-relaxed flex-1 mb-4">{project.description}</p>
          <div class="flex flex-wrap gap-2">
            {project.tech.map((t) => (
              <span class="px-2 py-1 rounded-md bg-white/[0.04] text-[10px] font-mono text-gray-500 uppercase tracking-wider">{t}</span>
            ))}
          </div>
          <div class="mt-4 pt-3 border-t border-white/5 flex items-center gap-1 text-xs text-accent-light opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            View on GitHub
            <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
