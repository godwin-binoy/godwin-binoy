---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Godwin Binoy — Developer & Linux Enthusiast',
  description = 'Self-taught developer from Kerala, India. Open-source, CLI tools, system optimization, building from web to OS.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Godwin Binoy" />
    <meta name="theme-color" content="#0a0a0f" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://godwin-binoy.github.io" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="noise-overlay">
    <slot />
  </body>
</html>
