---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Journey from '../components/Journey.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Connect from '../components/Connect.astro';
import NavDots from '../components/NavDots.astro';
import ParticleField from '../components/ParticleField.astro';
import ScrollController from '../components/ScrollController.astro';
---
<BaseLayout>
  <ParticleField />
  <NavDots />
  <main class="reel-container relative z-10">
    <Hero />
    <About />
    <Journey />
    <Skills />
    <Projects />
    <Connect />
  </main>
  <ScrollController />
</BaseLayout>
